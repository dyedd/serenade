# AI API Configuration
# 复制此文件为 .env 并填入你的API密钥（不要提交 .env）

# OpenAI API
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://aiping.cn/api/v1
OPENAI_MODEL=gpt-4o-mini

# Image Generation API
IMAGE_API_KEY=your_image_api_key_here
IMAGE_BASE_URL=https://aiping.cn/api/v1
IMAGE_MODEL=Doubao-Seedream-4.5

# Server Configuration (用于同步文件到服务器)
SERVER_HOST=your_server_ip_or_domain
SERVER_USER=root
SERVER_PATH=/opt/1panel/apps/openresty/openresty/www/sites/serenade/index

